{
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "start": "tsdx watch",
    "build": "tsdx build",
    "test": "tsdx test --passWithNoTests",
    "lint": "tsdx lint",
    "size": "size-limit",
    "analyze": "size-limit --why",
    "watch": "webpack -w",
    "serve": "node server.js"
  },
  "peerDependencies": {
    "react": ">=16"
  },
  "alias": {
    "system/*": [
      "./src/system/*"
    ],
    "elements/*": [
      "./src/system/components/*"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "tsdx lint"
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "name": "blog",
  "author": "mkelly",
  "module": "dist/blog.esm.js",
  "size-limit": [
    {
      "path": "dist/blog.cjs.production.min.js",
      "limit": "10 KB"
    },
    {
      "path": "dist/blog.esm.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@babel/cli": "^7.8.3",
    "@babel/core": "^7.13.10",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.13.10",
    "@babel/preset-env": "^7.8.3",
    "@babel/preset-react": "^7.12.13",
    "@babel/preset-typescript": "^7.8.3",
    "@size-limit/preset-small-lib": "^4.9.2",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.1",
    "@types/react-router-dom": "^5.1.7",
    "babel-loader": "^8.2.2",
    "html-loader": "^2.1.2",
    "husky": "^5.1.3",
    "live-server": "^1.2.1",
    "marked": "^2.0.1",
    "parcel-bundler": "^1.12.3",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "remark-loader": "^3.0.0",
    "rollup-plugin-string": "^3.0.0",
    "size-limit": "^4.9.2",
    "tsdx": "^0.14.1",
    "tslib": "^2.1.0",
    "typescript": "^4.2.2",
    "webpack": "^4.46.0",
    "webpack-cli": "^4.5.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.3.4",
    "deepmerge": "^4.2.2",
    "goober": "^2.0.33",
    "jotai": "^0.16.0",
    "react-app-polyfill": "^2.0.0",
    "react-helmet": "^6.1.0",
    "react-markdown": "^5.0.3",
    "react-merge-context": "^0.1.0",
    "react-router-dom": "^5.2.0",
    "react-with-i18n": "^0.1.3",
    "reakit": "^1.3.6",
    "remark-html": "^13.0.1"
  }
}
